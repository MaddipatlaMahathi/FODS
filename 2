import numpy as np

# 3x3 matrix (each row represents sales of a different product)
sales_data = np.array([
    [100, 120, 140],
    [200, 220, 240],
    [300, 320, 340]
])

# Calculate average price of all products sold
average_price = np.mean(sales_data)

print("Sales Data:")
print(sales_data)
print("Average Price of Products Sold:", average_price)
